{
  "name": "ai-botc",
  "private": true,
  "scripts": {
    "dev:all": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@ai-botc/web",
    "dev:party": "turbo run dev --filter=@ai-botc/party",
    "dev:dashboard": "open http://localhost:3000/dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "ws": "^8.19.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  }
}
